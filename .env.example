# Required for Gemini-powered analysis and quiz generation.
GEMINI_API_KEY=

# Allowed frontend origin for API CORS.
FRONTEND_URL=http://localhost:3000

# Backward-compatible CORS origin override.
# FRONTEND_URL takes precedence when both are set.
ACCESS_CONTROL_ALLOW_ORIGIN=http://localhost:3000

# Gemini model configuration.
GEMINI_PRIMARY_MODEL=gemini-2.0-flash

# Optional. Leave empty to use the built-in fallback list.
GEMINI_FALLBACK_MODEL=

# Thinking configuration.
# Enable only for models that support thinking.
GEMINI_ENABLE_THINKING=false

# 0 disables explicit thinking budget.
# Values below the model minimum may be ignored or normalized by the server config.
GEMINI_THINKING_BUDGET=0
